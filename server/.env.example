PORT=5000
MONGODB_URI=mongodb://127.0.0.1:27017/shopping-mall-demo
JWT_SECRET=your_jwt_secret_key_change_this
JWT_EXPIRES_IN=7d
# 포트원 V2 API Secret (콘솔 > 결제 연동 > API Keys)
PORTONE_API_SECRET=your_portone_v2_api_secret

# 카카오 로그인 (developers.kakao.com > 내 애플리케이션)
KAKAO_REST_API_KEY=your_kakao_rest_api_key
# Client Secret 사용 시 (보안 > Client Secret 활성화 후 발급)
KAKAO_CLIENT_SECRET=your_kakao_client_secret
# 카카오 콘솔 Redirect URI와 동일해야 함
KAKAO_REDIRECT_URI=http://localhost:5000/api/auth/kakao/callback
# OAuth 완료 후 돌아갈 프론트 주소
CLIENT_URL=http://localhost:5173

# 구글 로그인 (console.cloud.google.com > API 및 서비스 > 사용자 인증 정보)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# 네이버 로그인 (developers.naver.com > Application > API 설정)
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret
NAVER_REDIRECT_URI=http://localhost:5000/api/auth/naver/callback
